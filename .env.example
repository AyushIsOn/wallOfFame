# Copy to .env for local development (server reads process.env).

# Port the API/server listens on (Render sets this automatically in prod).
PORT=3000

# Admin login password and token signing secret. CHANGE THESE in production.
ADMIN_PASSWORD=change-me
TOKEN_SECRET=replace-with-a-long-random-string

# Leave DATABASE_URL EMPTY locally -> the server uses in-process PGlite
# (no database server needed). On Render this is set from the managed Postgres.
DATABASE_URL=
# Local PGlite data directory (only used when DATABASE_URL is empty).
PGLITE_DIR=./.data/pg

# Optional: n8n webhook that accepts { about: "..." } and returns { tags: [...] }.
# If unset, the server uses a built-in keyword extractor.
N8N_TAGS_WEBHOOK_URL=
